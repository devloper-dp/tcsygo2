# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay Payment Gateway
# Get these from your Razorpay dashboard: https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Application Configuration
VITE_APP_NAME=TCSYGO
VITE_APP_URL=http://localhost:5000

# Open Mapping Services (No key required)
# Uses OSRM, Nominatim, and Photon for directions and search

# Development Settings
NODE_ENV=development
